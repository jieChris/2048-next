{
  "name": "2048-next",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "audit:game-manager": "node scripts/game-manager-audit.mjs",
    "audit:refactor-closure": "node scripts/refactor-closure-audit.mjs",
    "test:unit": "vitest run tests/unit",
    "test:unit:core": "vitest run tests/unit/core-",
    "test:unit:watch": "vitest tests/unit",
    "test:smoke": "playwright test --config=playwright.config.ts",
    "test:smoke:history": "playwright test --config=playwright.config.ts \"tests/smoke/history-.*\\.smoke\\.spec\\.ts\"",
    "test:smoke:index-ui": "playwright test --config=playwright.config.ts --workers=1 \"tests/smoke/index-ui-.*\\.smoke\\.spec\\.ts\"",
    "test:smoke:pages": "playwright test --config=playwright.config.ts --workers=1 \"tests/smoke/pages-.*\\.smoke\\.spec\\.ts\"",
    "test:smoke:ci": "npm run test:smoke:history && npm run test:smoke:index-ui && npm run test:smoke:pages",
    "test:smoke:runtime-contract": "playwright test --config=playwright.config.ts tests/smoke/pages-runtime-contract.smoke.spec.ts",
    "test:smoke:replay-runtime": "playwright test --config=playwright.config.ts tests/smoke/pages-replay-runtime.smoke.spec.ts",
    "test:smoke:history-load": "playwright test --config=playwright.config.ts \"tests/smoke/history-records-.*\\.smoke\\.spec\\.ts\"",
    "test:smoke:play-replay": "playwright test --config=playwright.config.ts tests/smoke/pages-play-modes.smoke.spec.ts tests/smoke/pages-replay-runtime.smoke.spec.ts",
    "test:smoke:recent-regression": "playwright test --config=playwright.config.ts tests/smoke/pages-play-modes.smoke.spec.ts tests/smoke/pages-replay-runtime.smoke.spec.ts \"tests/smoke/history-records-.*\\.smoke\\.spec\\.ts\"",
    "test:smoke:headed": "playwright test --config=playwright.config.ts --headed",
    "verify:iterate": "npm run audit:game-manager && npm run test:unit:core && npm run test:smoke:runtime-contract && npm run test:smoke:play-replay",
    "verify:refactor": "node scripts/refactor-gate.mjs",
    "verify:refactor:ci": "node scripts/refactor-gate.mjs --smoke-script=test:smoke:ci",
    "verify:prepush": "npm run verify:refactor:ci",
    "verify:release-ready": "node scripts/release-readiness-check.mjs",
    "verify:release": "npm run verify:refactor:ci && npm run verify:release-ready",
    "verify:submit-ready": "npm run report:commit-split-check && npm run verify:release",
    "report:refactor-progress": "node scripts/refactor-progress-report.mjs",
    "report:commit-split-check": "node scripts/commit-split-check.mjs",
    "report:commit-batch": "node scripts/stage-commit-batch.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
